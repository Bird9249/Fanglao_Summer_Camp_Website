# cp .env.example .env แล้วแก้ค่าตามเครื่อง

# --- Camp registration (Fanglao Admin API) ---
ADMIN_API_URL=http://localhost:3000
CAMP_API_KEY=replace-with-camp-public-api-key
CAMP_EVENT_SLUG=summer-camp-2026
JAM_EVENT_SLUG=fanglao-jam-2026

# --- Public site URL (SEO, canonical, Open Graph) ---
SITE_URL=http://localhost:3001

# --- Google Analytics 4 (production only) ---
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Better Auth + PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
BETTER_AUTH_SECRET=replace-with-at-least-32-character-secret-key-here
BETTER_AUTH_URL=http://localhost:3001

# --- Object store (MinIO / S3) — ใช้กับ /api/upload และ /api/files ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=partzync
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
