# คัดลอกเป็นไฟล์ .env แล้วแก้ค่าตามเครื่องของคุณ
# cp .env.example .env

# PostgreSQL (ใช้ drizzle + postgres-js)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace

# Better Auth — production ต้องอย่างน้อย 32 ตัวอักษร (dev ในโค้ดมี fallback ถ้าไม่ใส่)
# สร้างได้ เช่น: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-character-secret-key-here

# URL ที่ผู้ใช้เข้าถึงแอป (ใช้เป็น baseURL / trustedOrigins)
# development ตัวอย่าง TanStack Start มักเป็น port 3000
BETTER_AUTH_URL=http://localhost:3000

# (ทางเลือก) ถ้าไม่ได้ตั้ง BETTER_AUTH_URL บางที่ในโค้ดจะ fallback มาที่ค่านี้
# VITE_APP_URL=http://localhost:3000

# Object store (MinIO / S3-compatible) — เหมือน Admin_Web; ถ้าไม่ครบจะได้ 503 จาก /api/upload/*
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=partzync
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
