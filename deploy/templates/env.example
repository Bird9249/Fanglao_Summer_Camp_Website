# คัดลอกไปที่เซิร์ฟเวอร์เป็น /etc/marketplace.env (หรือชื่อที่ตรงกับ app_name ใน group_vars)
# เช่น: sudo cp deploy/templates/env.example /etc/marketplace.env && sudo chmod 600 /etc/marketplace.env

NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://db_user:db_password@127.0.0.1:5432/marketplace
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-or-similar
CORS_ORIGIN=https://your-frontend-domain.example

# ตามที่ Better Auth / แอปใช้ (เพิ่มจาก .env.development หรือ auth config)
