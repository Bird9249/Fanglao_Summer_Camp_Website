# คัดลอกไปที่เซิร์ฟเวอร์เป็น /etc/summer-camp-2026.env
# sudo cp deploy/templates/env.example /etc/summer-camp-2026.env && sudo chmod 600 /etc/summer-camp-2026.env

NODE_ENV=production
PORT=3001

# --- Camp registration (Fanglao Admin API) ---
ADMIN_API_URL=https://admin.fanglaostudio.com
CAMP_API_KEY=replace-with-camp-public-api-key
CAMP_EVENT_SLUG=summer-camp-2026

# --- Public site URL (SEO, canonical, Open Graph) ---
SITE_URL=https://summer2026.fanglaostudio.com
BETTER_AUTH_URL=https://summer2026.fanglaostudio.com

# --- Google Analytics 4 (production only) ---
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Better Auth + PostgreSQL ---
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/fanglao
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-or-similar

# --- Object store (MinIO / S3) — ใช้กับ /api/upload และ /api/files ---
S3_ENDPOINT=https://s3.fanglaostudio.com
S3_BUCKET=fanglao
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
